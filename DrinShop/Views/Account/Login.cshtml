@model DrinShop.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    /* Primary: #6C4E31 - Nâu sữa, #DCC5A1 - Be kem */
    /* Secondary: #F5E9DA - Nền sáng, #A67C52 - Nâu nhạt */
    /* Accent: #8BC34A - Xanh matcha nhẹ */
    /* Text: #2A2A2A - Đen xám dễ đọc */

    :root {
        --bs-primary: #6C4E31; /* Nâu sữa */
        --bs-primary-light: #DCC5A1; /* Be kem */
        --bs-secondary: #A67C52; /* Nâu nhạt */
        --bs-light-background: #F5E9DA; /* Nền sáng */
        --bs-accent: #8BC34A; /* Xanh matcha nhẹ */
        --bs-text-color: #2A2A2A; /* Đen xám dễ đọc */
    }

    /* Áp dụng màu cho các thành phần chính của form */
    .text-primary, a.text-primary {
        color: var(--bs-primary) !important;
    }

    .btn-primary {
        --bs-btn-color: #fff;
        --bs-btn-bg: var(--bs-primary);
        --bs-btn-border-color: var(--bs-primary);
        --bs-btn-hover-bg: var(--bs-secondary);
        --bs-btn-hover-border-color: var(--bs-secondary);
        --bs-btn-active-bg: var(--bs-secondary);
        --bs-btn-active-border-color: var(--bs-secondary);
    }

    .card {
        background-color: #ffffff; /* Giữ nền card màu trắng để nổi bật */
        border: 1px solid var(--bs-primary-light) !important;
    }

    body {
        background-color: var(--bs-light-background);
        color: var(--bs-text-color);
    }

    .form-label, .fw-semibold, .text-muted {
        color: var(--bs-text-color) !important;
    }

    /* Cập nhật màu thông báo cho dễ nhìn */
    .alert-success {
        color: #0f5132;
        background-color: #d1e7dd;
        border-color: #badbcc;
    }

    .alert-danger {
        color: #842029;
        background-color: #f8d7da;
        border-color: #f5c2c7;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">

            @if (TempData["PasswordChangedSuccess"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-shield-check fs-4 me-3"></i>
                        <div>
                            <strong>Đổi mật khẩu thành công!</strong><br>
                            <small>Vì lý do bảo mật, bạn cần đăng nhập lại với mật khẩu mới.</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">Đăng nhập</h2>
                        <p class="text-muted">Chào mừng trở lại với DrinShop!</p>
                    </div>

                    <form asp-action="Login" method="post">
                        <input asp-for="ReturnUrl" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label fw-semibold">
                                Tên đăng nhập hoặc Email
                            </label>
                            <input asp-for="UserName"
                                   class="form-control form-control-lg"
                                   placeholder="Nhập tên đăng nhập hoặc email"
                                   autofocus="@(TempData["PasswordChangedSuccess"] != null ? "true" : "false")" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">
                                Mật khẩu @if (TempData["PasswordChangedSuccess"] != null)
                                {
                                    <small class="text-success">(mật khẩu mới)</small>
                                }
                            </label>
                            <input asp-for="Password"
                                   class="form-control form-control-lg"
                                   placeholder="Nhập mật khẩu" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label" style="color: var(--bs-text-color) !important;">
                                Ghi nhớ đăng nhập
                            </label>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Đăng nhập
                            </button>
                        </div>
                        <div class="d-grid gap-2">
                            <a href="/account/google-login" class="btn btn-danger btn-lg">
                                <i class="bi bi-google"></i> Đăng nhập bằng Google
                            </a>
                        </div>

                        <div class="text-center mt-3">
                            <a asp-action="ForgotPassword" class="text-decoration-none small" style="color: var(--bs-primary);">
                                Quên mật khẩu?
                            </a>
                        </div>

                        <hr class="my-4">

                        <div class="text-center">
                            <span class="text-muted">Chưa có tài khoản?</span>
                            <a asp-action="Register" class="text-decoration-none fw-semibold" style="color: var(--bs-primary);">
                                Đăng ký ngay
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-3" style="border: 1px solid var(--bs-primary-light) !important;">
                <div class="card-body">
                    <h6 class="card-title text-primary">Tài khoản test:</h6>
                    <small class="text-muted">
                        <strong>Admin:</strong> admin / Admin@123<br>
                        <strong>Staff:</strong> staff / Staff@123<br>
                        <strong>User:</strong> customer / Customer@123
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function loginWithGoogle() {
            // XÓA CACHE GOOGLE ACCOUNT PICKER
            if (typeof google !== 'undefined' && google.accounts) {
                google.accounts.id.cancel(); // Hủy session hiện tại
            }

            // Clear any existing auth state
            if (window.gapi && window.gapi.auth2) {
                const authInstance = window.gapi.auth2.getAuthInstance();
                if (authInstance) {
                    authInstance.signOut();
                }
            }

            // REDIRECT ĐẾN GOOGLE LOGIN VỚI THAM SỐ BẮT BUỘC CHỌN TÀI KHOẢN
            const returnUrl = new URLSearchParams(window.location.search).get('ReturnUrl');

            let googleLoginUrl = '/account/google-login';
            if (returnUrl) {
                googleLoginUrl += '?returnUrl=' + encodeURIComponent(returnUrl);
            }

            window.location.href = googleLoginUrl;
        }

        // TỰ ĐỘNG CLEAR GOOGLE AUTH KHI TẢI TRANG
        document.addEventListener('DOMContentLoaded', function() {
            // Clear localStorage related to Google
            Object.keys(localStorage).forEach(key => {
                if (key.includes('google') || key.includes('gapi')) {
                    localStorage.removeItem(key);
                }
            });

            // Clear sessionStorage related to Google
            Object.keys(sessionStorage).forEach(key => {
                if (key.includes('google') || key.includes('gapi')) {
                    sessionStorage.removeItem(key);
                }
            });
        });
    </script>
}