@model DrinShop.Models.Bundle
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var itemsCount = Model.BundleItems?.Count ?? 0;
    var totalOriginalPrice = Model.OriginalPrice;

    // Define custom CSS variables for easy maintenance
    const string PrimaryColor = "#6C4E31";
    const string SecondaryColor = "#A67C52";
    const string AccentColor = "#8BC34A";
    const string TextColor = "#2A2A2A";
    const string LightBgColor = "#F5E9DA";
    const string CreamBgColor = "#DCC5A1"; // Be kem
}
<!-- Thêm CSRF token -->
<form style="display: none;">
    @Html.AntiForgeryToken()
</form>
<style>
    /* Custom Colors and Styles */
    .text-primary-custom {
        color: @PrimaryColor !important;
    }

    .bg-primary-custom {
        background-color: @PrimaryColor !important;
    }

    .bg-cream-custom {
        background-color: @CreamBgColor !important;
    }

    .border-cream-custom {
        border-color: @CreamBgColor !important;
    }

    .text-accent-custom {
        color: @AccentColor !important;
    }

    .bg-accent-custom {
        background-color: @AccentColor !important;
    }

    .text-secondary-custom {
        color: @SecondaryColor !important;
    }

    .bg-light-custom {
        background-color: @LightBgColor !important;
    }

    .btn-primary-custom {
        color: white;
        background-color: @PrimaryColor;
        border-color: @PrimaryColor;
    }

        .btn-primary-custom:hover {
            background-color: @SecondaryColor;
            border-color: @SecondaryColor;
        }

    .btn-outline-secondary-custom {
        color: @PrimaryColor;
        border-color: @CreamBgColor;
    }

        .btn-outline-secondary-custom:hover {
            background-color: @LightBgColor;
            color: @PrimaryColor;
            border-color: @PrimaryColor;
        }

    .btn-accent-custom { /* For Add to Cart button */
        color: white;
        background-color: @AccentColor;
        border-color: @AccentColor;
    }

        .btn-accent-custom:hover {
            background-color: darken( @AccentColor, 10%); /* Assuming a LESS/SASS like darken function, use fixed color if not possible */
            background-color: #6AA84F; /* Darker shade of matcha */
            border-color: #6AA84F;
        }

    .table-light-custom th {
        background-color: @CreamBgColor;
        color: @TextColor;
        border-bottom: 2px solid @PrimaryColor;
    }

    .text-body-custom {
        color: @TextColor !important;
    }

    a.text-dark:hover {
        color: @PrimaryColor !important;
    }
    /* Overall text color */
    body {
        color: @TextColor;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h1 class="h3 mb-0 text-primary-custom">
            <i class="fas fa-cube me-2"></i> Chi tiết Combo
        </h1>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary-custom">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-light-custom p-2 rounded">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-secondary-custom">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-secondary-custom">Combo</a></li>
            <li class="breadcrumb-item active text-primary-custom" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-body-custom" style="background-color: #d1e7dd; border-color: @AccentColor;">
            <i class="fas fa-check-circle text-accent-custom"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show text-body-custom" style="background-color: #f8d7da; border-color: #f5c6cb;">
            <i class="fas fa-exclamation-triangle text-danger"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4 border-cream-custom">
                <div class="card-body p-3">
                    <div class="text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img id="mainImage" src="@Model.ImageUrl" alt="@Model.Name"
                                 class="img-fluid rounded border border-cream-custom" style="max-height: 400px; object-fit: contain; width: 100%;" />
                        }
                        else
                        {
                            <div class="bg-light-custom d-flex align-items-center justify-content-center rounded border border-cream-custom"
                                 style="height: 400px; width: 100%;">
                                <div class="text-secondary-custom text-center">
                                    <i class="fas fa-box-open" style="font-size: 5rem;"></i>
                                    <p class="mt-3 mb-0">Chưa có ảnh combo</p>
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.BundleItems != null && Model.BundleItems.Any())
                    {
                        <div class="row g-2 pt-3 border-top border-cream-custom">
                            <div class="col-12">
                                <h6 class="text-primary-custom mb-3 fw-bold">
                                    <i class="fas fa-images"></i> Sản phẩm trong combo
                                </h6>
                            </div>
                            @foreach (var item in Model.BundleItems.Take(8)) // Hiển thị tối đa 8 ảnh
                            {
                                var productImage = item.Variant?.Product?.ProductImages?
                                .OrderByDescending(x => x.IsDefault).FirstOrDefault()?.ImageUrl ?? "/images/placeholder.png";

                                <div class="col-3">
                                    <img src="@productImage" alt="@item.Variant.Product.ProductName"
                                         class="img-thumbnail cursor-pointer border-cream-custom"
                                         style="height: 80px; width: 100%; object-fit: cover;"
                                         data-bs-toggle="tooltip"
                                         title="@item.Variant.Product.ProductName"
                                         onclick="changeMainImage('@productImage')" />
                                </div>
                            }
                            @if (Model.BundleItems.Count > 8)
                            {
                                <div class="col-12 text-center mt-2">
                                    <small class="text-secondary-custom">
                                        và @(Model.BundleItems.Count - 8) sản phẩm khác...
                                    </small>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card shadow-sm border-cream-custom">
                    <div class="card-header bg-cream-custom">
                        <h6 class="mb-0 text-primary-custom"><strong>Mô tả combo</strong></h6>
                    </div>
                    <div class="card-body">
                        <p class="mb-0 text-body-custom">@Html.Raw(Model.Description.Replace(Environment.NewLine, "<br/>"))</p>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-6">
            <div class="card shadow-lg border-primary-custom">
                <div class="card-header bg-primary-custom text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i> Thông tin combo
                    </h5>
                </div>
                <div class="card-body">
                    <h3 class="mb-3 text-primary-custom fw-bolder">@Model.Name</h3>

                    @if (!string.IsNullOrEmpty(Model.Code))
                    {
                        <div class="mb-3">
                            <span class="badge bg-secondary-custom fs-6">#@Model.Code</span>
                        </div>
                    }

                    <dl class="row mb-4">
                        <dt class="col-sm-4 text-secondary-custom">Số sản phẩm</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-primary-custom fs-6">@itemsCount sản phẩm</span>
                        </dd>

                        <dt class="col-sm-4 text-secondary-custom">Tồn kho</dt>
                        <dd class="col-sm-8">
                            @if (Model.AvailableStock > 0)
                            {
                                if (Model.IsLowStock)
                                {
                                    <span class="badge bg-warning text-dark fs-6">
                                        @Model.AvailableStock combo
                                    </span>
                                    <small class="d-block text-warning">
                                        <i class="fas fa-exclamation-triangle"></i> Sắp hết hàng
                                    </small>
                                }
                                else
                                {
                                    <span class="badge bg-accent-custom fs-6">
                                        @Model.AvailableStock combo
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-danger fs-6">Hết hàng</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-secondary-custom">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @if (Model.Status)
                            {
                                <span class="badge bg-accent-custom fs-6">
                                    <i class="fas fa-check-circle"></i> Đang bán
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6">
                                    <i class="fas fa-times-circle"></i> Ngừng bán
                                </span>
                            }
                        </dd>
                    </dl>

                    <div class="card border-accent-custom mb-4 bg-light-custom">
                        <div class="card-body">
                            <h6 class="card-title text-accent-custom fw-bold border-bottom pb-2 mb-3">
                                <i class="fas fa-tags"></i> Thông tin giá
                            </h6>

                            @if (Model.OriginalPrice > Model.FinalPrice)
                            {
                                <div class="row align-items-center">
                                    <div class="col-sm-6">
                                        <div class="text-secondary-custom">
                                            <small>Giá lẻ tổng:</small>
                                            <div class="text-decoration-line-through fs-5">
                                                @Model.OriginalPrice.ToString("N0")₫
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 text-end">
                                        <div class="text-danger">
                                            <small>Giá combo:</small>
                                            <div class="h3 mb-1 fw-bold">@Model.FinalPrice.ToString("N0")₫</div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="my-2 border-primary-custom">

                                <div class="row text-center">
                                    <div class="col-sm-6 mt-2">
                                        <div class="text-accent-custom fw-bold">
                                            Tiết kiệm: @((Model.OriginalPrice - Model.FinalPrice).ToString("N0"))₫
                                        </div>
                                    </div>
                                    <div class="col-sm-6 mt-2">
                                        <div class="text-danger">
                                            <span class="badge bg-danger fs-6">
                                                Giảm: -@Model.DiscountPercentage.ToString("0.0")%
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center">
                                    <div class="h3 text-danger mb-1 fw-bold">@Model.FinalPrice.ToString("N0")₫</div>
                                    <small class="text-secondary-custom">Giá combo ưu đãi</small>
                                </div>
                            }
                        </div>
                    </div>

                    @if (Model.AvailableStock > 0 && Model.Status)
                    {
                        <div id="addToCartSection" class="mb-4">
                            <div class="mb-3">
                                <label for="quantity" class="form-label fw-bold text-primary-custom">
                                    <i class="fas fa-shopping-basket"></i> Số lượng:
                                </label>
                                <div class="input-group" style="max-width: 200px;">
                                    <button class="btn btn-outline-secondary-custom" type="button" onclick="decreaseQuantity()">
                                        <i class="fas fa-minus"></i>
                                    </button>
                                    <input type="number" id="quantity" class="form-control text-center"
                                           value="1" min="1" max="@Model.AvailableStock" />
                                    <button class="btn btn-outline-secondary-custom" type="button" onclick="increaseQuantity()">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                                <small class="text-secondary-custom">Còn @Model.AvailableStock combo</small>
                            </div>

                            <div class="card border-primary-custom mb-3">
                                <div class="card-body py-2 bg-light-custom">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold text-primary-custom">Thành tiền:</span>
                                        <span id="totalPrice" class="h4 text-danger mb-0 fw-bolder">
                                            @Model.FinalPrice.ToString("N0")₫
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-2">
                                <div class="col-12">
                                    <button id="addToCartBtn" class="btn btn-lg btn-accent-custom w-100 shadow" onclick="addToCart()">
                                        <i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng
                                    </button>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-outline-danger btn-lg w-100" onclick="addToWishlist()">
                                        <i class="far fa-heart"></i> Yêu thích
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger text-body-custom">
                            <i class="fas fa-exclamation-triangle"></i>
                            Combo hiện đang **hết hàng** hoặc **ngừng bán**.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model.BundleItems != null && Model.BundleItems.Any())
    {
        <div class="mt-5">
            <div class="card shadow-sm border-primary-custom">
                <div class="card-header bg-primary-custom text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-clipboard-list me-2"></i> Chi tiết sản phẩm trong combo
                        <span class="badge bg-light text-primary-custom ms-2">@itemsCount</span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light-custom">
                                <tr>
                                    <th style="width: 80px;" class="text-center">Ảnh</th>
                                    <th>Sản phẩm</th>
                                    <th style="width: 120px;" class="text-center">Biến thể</th>
                                    <th style="width: 100px;" class="text-center">Số lượng</th>
                                    <th style="width: 120px;" class="text-end">Giá lẻ</th>
                                    <th style="width: 120px;" class="text-end">Tổng tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.BundleItems.OrderBy(x => x.BundleItemId))
                                {
                                    var productImage = item.Variant?.Product?.ProductImages?
                                    .OrderByDescending(x => x.IsDefault).FirstOrDefault()?.ImageUrl ?? "/images/placeholder.png";
                                    var subtotal = item.Variant.UnitPrice * item.Quantity;

                                    <tr>
                                        <td class="text-center">
                                            <img src="@productImage" alt="@item.Variant.Product.ProductName"
                                                 class="rounded border border-cream-custom" style="width: 50px; height: 50px; object-fit: cover;" />
                                        </td>
                                        <td>
                                            <strong class="text-primary-custom">@item.Variant.Product.ProductName</strong>
                                            @if (!string.IsNullOrEmpty(item.Variant.Product.Description))
                                            {
                                                <small class="text-secondary-custom d-block">
                                                    @(item.Variant.Product.Description.Length > 50 ?
                                                        item.Variant.Product.Description.Substring(0, 50) + "..." :
                                                        item.Variant.Product.Description)
                                                </small>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary-custom">@item.Variant.VariantName</span>
                                            <small class="text-muted d-block">Còn: @item.Variant.Stock</small>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-primary-custom fs-6">@item.Quantity</span>
                                        </td>
                                        <td class="text-end">
                                            <strong>@item.Variant.UnitPrice.ToString("N0")₫</strong>
                                        </td>
                                        <td class="text-end">
                                            <strong class="text-accent-custom">@subtotal.ToString("N0")₫</strong>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light-custom">
                                <tr>
                                    <td colspan="4" class="text-end fw-bold">Tổng giá lẻ:</td>
                                    <td class="text-end fw-bold text-secondary-custom">
                                        @totalOriginalPrice.ToString("N0")₫
                                    </td>
                                    <td class="text-end fw-bold text-danger fs-5">
                                        @Model.FinalPrice.ToString("N0")₫
                                    </td>
                                </tr>
                                @if (Model.OriginalPrice > Model.FinalPrice)
                                {
                                    <tr style="background-color: #e6ffec;">
                                        <td colspan="5" class="text-end fw-bold text-accent-custom">
                                            <i class="fas fa-gift me-2"></i> Bạn tiết kiệm được:
                                        </td>
                                        <td class="text-end fw-bold text-accent-custom fs-5">
                                            @((Model.OriginalPrice - Model.FinalPrice).ToString("N0"))₫
                                        </td>
                                    </tr>
                                }
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @{
        // Giả sử có related combos trong ViewBag
        var relatedCombos = ViewBag.RelatedCombos as List<DrinShop.Models.Bundle>;
    }
    @if (relatedCombos != null && relatedCombos.Any())
    {
        <div class="mt-5">
            <h4 class="mb-4 text-primary-custom border-bottom pb-2">
                <i class="fas fa-sync-alt me-2"></i> Combo khác bạn có thể thích
            </h4>
            <div class="row">
                @foreach (var combo in relatedCombos.Take(4))
                {
                    var comboImage = !string.IsNullOrEmpty(combo.ImageUrl) ? combo.ImageUrl :
                    (combo.BundleItems?.FirstOrDefault()?.Variant?.Product?.ProductImages?
                    .OrderByDescending(x => x.IsDefault).FirstOrDefault()?.ImageUrl ?? "/images/placeholder.png");

                    <div class="col-md-3 col-sm-6 mb-4">
                        <div class="card h-100 combo-card shadow-sm border-cream-custom">
                            <a asp-action="Details" asp-route-id="@combo.BundleId">
                                <img src="@comboImage" class="card-img-top rounded-top" alt="@combo.Name"
                                     style="height: 200px; object-fit: cover;" />
                            </a>
                            <div class="card-body">
                                <h6 class="card-title">
                                    <a asp-action="Details" asp-route-id="@combo.BundleId"
                                       class="text-body-custom text-decoration-none fw-bold">
                                        @combo.Name
                                    </a>
                                </h6>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-secondary-custom">
                                        @(combo.BundleItems?.Count ?? 0) sản phẩm
                                    </small>
                                    @if (combo.DiscountPercentage > 0)
                                    {
                                        <span class="badge bg-danger">-@combo.DiscountPercentage.ToString("0.0")%</span>
                                    }
                                </div>
                                <p class="text-danger mb-2 fw-bolder fs-5">@combo.FinalPrice.ToString("N0")₫</p>
                                <a asp-action="Details" asp-route-id="@combo.BundleId"
                                   class="btn btn-sm btn-primary-custom w-100">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        let basePrice = @Model.FinalPrice;
        let maxStock = @Model.AvailableStock;
        const totalPriceElement = document.getElementById('totalPrice');

        // Quantity controls
        function increaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue < maxStock) {
                input.value = currentValue + 1;
                updateTotalPrice();
            }
        }

        function decreaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) {
                input.value = currentValue - 1;
                updateTotalPrice();
            }
        }

        // Update total price based on quantity
        function updateTotalPrice() {
            const quantity = parseInt(document.getElementById('quantity').value) || 1;
            const totalPrice = basePrice * quantity;
            totalPriceElement.textContent = totalPrice.toLocaleString('vi-VN') + '₫';

            // Highlight total price change (optional animation effect)
            totalPriceElement.classList.add('animate-scale');
            setTimeout(() => {
                totalPriceElement.classList.remove('animate-scale');
            }, 300);
        }

                // Add to cart function
        function addToCart() {
            const quantity = parseInt(document.getElementById('quantity').value) || 1;

            if (quantity <= 0 || quantity > maxStock) {
                if (typeof toastr !== 'undefined') {
                    toastr.error(`Số lượng phải từ 1 đến ${maxStock}.`);
                } else {
                    alert(`Số lượng phải từ 1 đến ${maxStock}.`);
                }
                return;
            }

            // Disable button to prevent multiple clicks
            const addButton = document.getElementById('addToCartBtn');
            addButton.disabled = true;
            addButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang thêm...';

            // Make AJAX request to add bundle to cart
            fetch('/Cart/AddBundle', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({
                    BundleId: @Model.BundleId,
                    Quantity: quantity
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Show success message
                    if (typeof toastr !== 'undefined') {
                        toastr.success(data.message);
                    } else {
                        alert(data.message);
                    }

                    // Update cart count if available
                    if (data.cartCount !== undefined) {
                        const cartCountElements = document.querySelectorAll('.cart-count, #cartCount, [data-cart-count]');
                        cartCountElements.forEach(element => {
                            element.textContent = data.cartCount;
                        });
                    }

                    // Reset quantity to 1
                    document.getElementById('quantity').value = 1;
                    updateTotalPrice();
                } else {
                    // Show error message
                    if (typeof toastr !== 'undefined') {
                        toastr.error(data.message);
                    } else {
                        alert(data.message);
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (typeof toastr !== 'undefined') {
                    toastr.error('Đã xảy ra lỗi khi thêm vào giỏ hàng!');
                } else {
                    alert('Đã xảy ra lỗi khi thêm vào giỏ hàng!');
                }
            })
            .finally(() => {
                // Re-enable button
                addButton.disabled = false;
                addButton.innerHTML = '<i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng';
            });
        }


        // Add to wishlist (placeholder)
        function addToWishlist() {
            if (typeof toastr !== 'undefined') {
                toastr.info('Chức năng yêu thích đang được phát triển!');
            } else {
                alert('Chức năng yêu thích đang được phát triển!');
            }
        }

        // Change main image
        function changeMainImage(imageUrl) {
            document.getElementById('mainImage').src = imageUrl;
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Quantity input event listener
            const quantityInput = document.getElementById('quantity');
            if (quantityInput) {
                quantityInput.addEventListener('input', function() {
                    let val = parseInt(this.value);
                    if (isNaN(val) || val < 1) {
                        this.value = 1;
                    } else if (val > maxStock) {
                        this.value = maxStock;
                    }
                    updateTotalPrice();
                });

                quantityInput.addEventListener('change', updateTotalPrice);
            }

            // Initialize price display
            updateTotalPrice();
        });
    </script>
}

