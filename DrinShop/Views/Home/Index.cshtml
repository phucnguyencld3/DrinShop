@model object
@{
    ViewData["Title"] = "Trang chủ - DrinShop";
    var newProducts = ViewBag.NewProducts as List<DrinShop.Models.Product>;
    var featuredProducts = ViewBag.FeaturedProducts as List<DrinShop.Models.Product>;
    var featuredCategories = ViewBag.FeaturedCategories as List<DrinShop.Models.Category>;
    var selectedCategory = ViewBag.SelectedCategory as DrinShop.Models.Category;
}

@* Định nghĩa màu chủ đạo: Primary Dark #6C4E31, Primary Light #DCC5A1 *@

@if (selectedCategory != null)
{
    <div class="container mt-5">
        <div class="alert alert-milk-filter">
            <h4><i class="fas fa-filter text-primary-dark"></i> Đang hiển thị sản phẩm thuộc danh mục: <strong>@selectedCategory.CategoryName</strong></h4>
            <p class="mb-2">@selectedCategory.Description</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary-dark btn-sm">
                <i class="fas fa-times"></i> Bỏ lọc
            </a>
        </div>
    </div>
}
else
{
    <div class="hero-section bg-primary-light text-primary-dark py-5 mb-5 shadow-lg">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-4 fw-bold mb-3">
                        Chào mừng đến với **DrinShop**
                    </h1>
                    <p class="lead mb-4 text-text-dark">
                        Khám phá hương vị tuyệt vời từ những ly đồ uống chất lượng cao.
                        Từ cà phê thơm ngon đến trà sữa độc đáo, chúng tôi có tất cả!
                    </p>
                    <div class="d-flex gap-3">
                        <a asp-controller="Products" asp-action="Index" class="btn btn-primary-dark btn-lg">
                            <i class="fas fa-shopping-bag"></i> Mua ngay
                        </a>
                        <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-primary-dark btn-lg">
                            <i class="fas fa-list"></i> Xem danh mục
                        </a>
                    </div>
                </div>
                <div class="col-lg-6 text-center mt-4 mt-lg-0">

                    @* Ảnh sản phẩm minh họa cho Hero Section *@
                </div>
            </div>
        </div>
    </div>
}

<div class="container py-5">
    @if (newProducts != null && newProducts.Any())
    {
        <div class="section-title mb-4">
            <h2 class="display-6 fw-bold text-primary-dark">
                <i class="fas fa-star text-accent-light me-2"></i> @* Dùng màu Accent cho icon nổi bật *@
                @if (selectedCategory != null)
                {
                    <text>Sản phẩm **@selectedCategory.CategoryName**</text>
                }
                else
                {
                    <text>Sản phẩm mới nhất</text>
                }
            </h2>
            <hr class="separator-primary-dark" />
        </div>

        <div class="row mb-5 product-grid">
            @foreach (var product in newProducts)
            {
                var defaultImage = product.ProductImages?.FirstOrDefault(pi => pi.IsDefault)?.ImageUrl
                ?? product.ProductImages?.FirstOrDefault()?.ImageUrl
                ?? "/images/no-image.png";
                var minPrice = product.Variants?.Any() == true ? product.Variants.Min(v => v.UnitPrice) : 0;
                var maxPrice = product.Variants?.Any() == true ? product.Variants.Max(v => v.UnitPrice) : 0;
                var totalStock = product.Variants?.Sum(v => v.Stock) ?? 0;

                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="card h-100 product-card shadow-sm">
                        <div class="product-image-container">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="text-decoration-none">
                                <img src="@defaultImage" class="card-img-top product-img" alt="@product.ProductName" style="height: 250px; object-fit: cover;">
                            </a>

                            @if (totalStock == 0)
                            {
                                <span class="badge bg-danger position-absolute m-2 top-0 end-0">Hết hàng</span>
                            }
                            else if (totalStock < 10)
                            {
                                <span class="badge bg-warning position-absolute m-2 top-0 end-0">Sắp hết</span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title mb-1">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="text-text-dark text-decoration-none product-name-link">
                                    @product.ProductName
                                </a>
                            </h6>

                            <p class="text-secondary-dark small mb-2 product-category">
                                <i class="fas fa-tag text-secondary-dark"></i> @product.Category?.CategoryName
                            </p>

                            @if (minPrice > 0)
                            {
                                <div class="mb-3 mt-auto">
                                    @if (minPrice == maxPrice)
                                    {
                                        <span class="h6 text-primary-dark fw-bold mb-0">@minPrice.ToString("N0") VNĐ</span>
                                    }
                                    else
                                    {
                                        <span class="h6 text-primary-dark fw-bold mb-0">@minPrice.ToString("N0") - @maxPrice.ToString("N0") VNĐ</span>
                                    }
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted small-stock">
                                    <i class="fas fa-box"></i> Còn: **@totalStock**
                                </small>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="btn btn-secondary-dark">
                                    <i class="fas fa-eye"></i> Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (selectedCategory == null)
    {
        @if (featuredCategories != null && featuredCategories.Any())
        {
            <div class="section-title mb-4">
                <h2 class="display-6 fw-bold text-primary-dark">
                    <i class="fas fa-bookmark text-accent-light me-2"></i> Danh mục nổi bật
                </h2>
                <hr class="separator-primary-dark" />
            </div>

            <div class="row mb-5">
                @foreach (var category in featuredCategories)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 category-card shadow-sm border-0 bg-secondary-light">
                            <div class="card-body text-center p-4">
                                <div class="category-icon mb-3">
                                    <i class="fas fa-coffee fa-3x text-primary-dark"></i> @* Icon màu nâu đậm *@
                                </div>
                                <h5 class="card-title text-text-dark mb-3">**@category.CategoryName**</h5>
                                @if (!string.IsNullOrEmpty(category.Description))
                                {
                                    <p class="card-text text-secondary-dark mb-3">@category.Description</p>
                                }
                                <div class="d-grid">
                                    <a asp-controller="Home" asp-action="Index" asp-route-categoryId="@category.CategoryID" class="btn btn-primary-outline">
                                        <i class="fas fa-arrow-right"></i> Xem sản phẩm
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (featuredProducts != null && featuredProducts.Any() && newProducts != null && !newProducts.Select(p => p.ProductID).Intersect(featuredProducts.Select(p => p.ProductID)).Any())
        {
            <div class="section-title mb-4">
                <h2 class="display-6 fw-bold text-primary-dark">
                    <i class="fas fa-fire-alt text-accent-light me-2"></i> Sản phẩm bán chạy
                </h2>
                <hr class="separator-primary-dark" />
            </div>

            <div class="row mb-5 product-grid">
                @foreach (var product in featuredProducts)
                {
                    var defaultImage = product.ProductImages?.FirstOrDefault(pi => pi.IsDefault)?.ImageUrl
                    ?? product.ProductImages?.FirstOrDefault()?.ImageUrl
                    ?? "/images/no-image.png";
                    var minPrice = product.Variants?.Any() == true ? product.Variants.Min(v => v.UnitPrice) : 0;
                    var maxPrice = product.Variants?.Any() == true ? product.Variants.Max(v => v.UnitPrice) : 0;
                    var totalStock = product.Variants?.Sum(v => v.Stock) ?? 0;

                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="card h-100 product-card shadow-sm">
                            <div class="product-image-container">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="text-decoration-none">
                                    <img src="@defaultImage" class="card-img-top product-img" alt="@product.ProductName" style="height: 250px; object-fit: cover;">
                                </a>

                                @if (totalStock == 0)
                                {
                                    <span class="badge bg-danger position-absolute m-2 top-0 end-0">Hết hàng</span>
                                }
                                else if (totalStock < 10)
                                {
                                    <span class="badge bg-warning position-absolute m-2 top-0 end-0">Sắp hết</span>
                                }
                                else
                                {
                                    <span class="badge bg-accent-light position-absolute m-2 top-0 end-0 text-dark"><i class="fas fa-hot-tub"></i> Hot</span> @* Badge màu xanh Matcha *@
                                }
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title mb-1">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="text-text-dark text-decoration-none product-name-link">
                                        @product.ProductName
                                    </a>
                                </h6>

                                <p class="text-secondary-dark small mb-2 product-category">
                                    <i class="fas fa-tag text-secondary-dark"></i> @product.Category?.CategoryName
                                </p>

                                @if (minPrice > 0)
                                {
                                    <div class="mb-3 mt-auto">
                                        @if (minPrice == maxPrice)
                                        {
                                            <span class="h6 text-primary-dark fw-bold mb-0">@minPrice.ToString("N0") VNĐ</span>
                                        }
                                        else
                                        {
                                            <span class="h6 text-primary-dark fw-bold mb-0">@minPrice.ToString("N0") - @maxPrice.ToString("N0") VNĐ</span>
                                        }
                                    </div>
                                }

                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted small-stock">
                                        <i class="fas fa-box"></i> Còn: **@totalStock**
                                    </small>
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="btn btn-secondary-dark-outline">
                                        <i class="fas fa-shopping-cart"></i> Đặt hàng
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="row text-center mb-5 features-section">
            <div class="section-title mb-4">
                <h2 class="display-6 fw-bold text-primary-dark">
                    <i class="fas fa-rocket text-accent-light me-2"></i> Tại sao chọn DrinShop?
                </h2>
                <hr class="separator-primary-dark" />
            </div>

            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card border-0 h-100 feature-card shadow-sm bg-secondary-light">
                    <div class="card-body p-4">
                        <i class="fas fa-medal fa-3x text-primary-dark mb-3 feature-icon"></i>
                        <h5 class="fw-bold text-text-dark">Chất lượng cao</h5>
                        <p class="text-secondary-dark">Nguyên liệu tươi ngon, công thức độc quyền</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card border-0 h-100 feature-card shadow-sm bg-secondary-light">
                    <div class="card-body p-4">
                        <i class="fas fa-shipping-fast fa-3x text-primary-dark mb-3 feature-icon"></i>
                        <h5 class="fw-bold text-text-dark">Giao hàng nhanh</h5>
                        <p class="text-secondary-dark">Giao hàng trong 30 phút nội thành</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card border-0 h-100 feature-card shadow-sm bg-secondary-light">
                    <div class="card-body p-4">
                        <i class="fas fa-headset fa-3x text-primary-dark mb-3 feature-icon"></i>
                        <h5 class="fw-bold text-text-dark">Hỗ trợ 24/7</h5>
                        <p class="text-secondary-dark">Đội ngũ tư vấn nhiệt tình, chuyên nghiệp</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-primary-dark rounded p-5 text-center shadow-lg cta-section">
            <h3 class="mb-3 fw-bold text-primary-light">Bắt đầu đặt hàng ngay hôm nay!</h3>
            <p class="text-primary-light mb-4 lead">Trải nghiệm hương vị tuyệt vời cùng DrinShop</p>
            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Products" asp-action="Index" class="btn btn-accent-cta btn-lg cta-button">
                    <i class="fas fa-shopping-cart"></i> Đặt hàng ngay
                </a>
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg cta-button">
                        <i class="fas fa-user-plus"></i> Đăng ký thành viên
                    </a>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Hiệu ứng hover cho tất cả các card sản phẩm và danh mục
            const hoverCards = document.querySelectorAll('.product-card, .category-card, .feature-card');
            hoverCards.forEach(card => {
                card.style.transition = 'transform 0.3s ease, box-shadow 0.3s ease';

                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-5px)';
                    this.style.boxShadow = '0 15px 30px rgba(108, 78, 49, 0.3)'; // Ánh sáng nâu nhẹ
                });

                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0)';
                    this.style.boxShadow = '0 0.5rem 1rem rgba(0,0,0,.15)!important'; /* Shadow mặc định (hoặc shadow-sm) */
                });
            });

            // Hiệu ứng zoom nhẹ cho ảnh sản phẩm
            const productImages = document.querySelectorAll('.product-img');
            productImages.forEach(img => {
                img.style.transition = 'transform 0.5s ease';
                img.closest('.product-card').addEventListener('mouseenter', function() {
                    img.style.transform = 'scale(1.05)';
                });
                img.closest('.product-card').addEventListener('mouseleave', function() {
                    img.style.transform = 'scale(1)';
                });
            });
        });
    </script>
}

@section Styles {
    <style>
        /* Định nghĩa màu chủ đạo */
        :root {
            --drinshop-primary-dark: #6C4E31; /* Nâu sữa - Main Dark */
            --drinshop-primary-light: #DCC5A1; /* Be kem - Main Light */
            --drinshop-secondary-dark: #A67C52; /* Nâu nhạt - Secondary */
            --drinshop-background-light: #F5E9DA; /* Nền sáng */
            --drinshop-accent-light: #8BC34A; /* Xanh Matcha */
            --drinshop-text-dark: #2A2A2A; /* Đen xám */
        }

        /* 0. Màu chữ (Text Color) */
        .text-text-dark {
            color: var(--drinshop-text-dark) !important;
        }

        /* 1. Thay thế màu Hero Section (Primary) */
        .hero-section {
            background-color: var(--drinshop-primary-light) !important;
            color: var(--drinshop-primary-dark) !important;
            border-bottom: 5px solid var(--drinshop-primary-dark);
        }

        /* 2. Màu chữ, Icon và Tiêu đề */
        .text-primary-dark {
            color: var(--drinshop-primary-dark) !important;
        }

        .text-secondary-dark {
            color: var(--drinshop-secondary-dark) !important;
        }

        .text-accent-light {
            color: var(--drinshop-accent-light) !important;
            text-shadow: 1px 1px 1px rgba(0, 0, 0, 0.1);
        }

        .separator-primary-dark {
            border-top: 3px solid var(--drinshop-primary-dark);
            width: 80px;
            margin-left: 0;
            opacity: 1;
        }

        /* 3. Nút bấm (Buttons) */
        .btn-primary-dark { /* Nút CTA/MUA NGAY - Nền Nâu đậm */
            color: white;
            background-color: var(--drinshop-primary-dark);
            border-color: var(--drinshop-primary-dark);
            font-weight: 600;
        }

            .btn-primary-dark:hover {
                color: white;
                background-color: #594028; /* Tối hơn chút */
                border-color: #594028;
            }

        .btn-outline-primary-dark { /* Nút viền trong Hero */
            color: var(--drinshop-primary-dark);
            border-color: var(--drinshop-primary-dark);
            font-weight: 600;
        }

            .btn-outline-primary-dark:hover {
                color: white;
                background-color: var(--drinshop-primary-dark);
            }

        .btn-secondary-dark { /* Nút chi tiết sản phẩm - Nền Nâu nhạt */
            color: white;
            background-color: var(--drinshop-secondary-dark);
            border-color: var(--drinshop-secondary-dark);
            font-weight: 500;
        }

            .btn-secondary-dark:hover {
                color: white;
                background-color: #8C6A43;
                border-color: #8C6A43;
            }

        .btn-secondary-dark-outline { /* Nút Đặt hàng */
            color: var(--drinshop-secondary-dark);
            border-color: var(--drinshop-secondary-dark);
            font-weight: 500;
        }

            .btn-secondary-dark-outline:hover {
                color: white;
                background-color: var(--drinshop-secondary-dark);
            }

        .btn-primary-outline { /* Nút Xem sản phẩm trong Category */
            color: var(--drinshop-primary-dark);
            border-color: var(--drinshop-primary-dark);
            font-weight: 500;
        }

            .btn-primary-outline:hover {
                color: white;
                background-color: var(--drinshop-primary-dark);
            }

        .btn-accent-cta { /* Nút CTA nổi bật (Đặt hàng ngay) */
            color: var(--drinshop-text-dark);
            background-color: var(--drinshop-accent-light);
            border-color: var(--drinshop-accent-light);
            font-weight: 700;
            box-shadow: 0 5px 15px rgba(139, 195, 74, 0.4);
        }

            .btn-accent-cta:hover {
                background-color: #79A940;
                border-color: #79A940;
            }


        /* 4. Background phụ */
        .bg-secondary-light {
            background-color: var(--drinshop-background-light) !important; /* Nền sáng #F5E9DA */
        }

        .badge.bg-accent-light {
            background-color: var(--drinshop-accent-light) !important;
        }

        /* 5. Alert khi lọc danh mục */
        .alert-milk-filter {
            background-color: var(--drinshop-background-light); /* Nền sáng #F5E9DA */
            border-left: 5px solid var(--drinshop-primary-dark);
            color: var(--drinshop-text-dark);
            border-radius: 8px;
        }

        /* 6. Call To Action */
        .bg-primary-dark {
            background-color: var(--drinshop-primary-dark) !important;
        }

        .cta-section {
            border: 2px dashed var(--drinshop-accent-light);
        }

    </style>
}