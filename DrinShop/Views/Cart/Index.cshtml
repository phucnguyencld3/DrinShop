@model DrinShop.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb custom-breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="custom-link">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Giỏ hàng</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-12 col-md-8 col-lg-8 mb-3">
            <div class="card shadow-sm custom-card">
                <div class="card-header custom-bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-shopping-cart"></i> Giỏ hàng của bạn
                        @if (Model.CartDetails != null && Model.CartDetails.Any())
                        {
                            <span class="badge bg-light text-dark ms-2 custom-text-dark">@Model.CartDetails.Sum(cd => cd.Quantity) sản phẩm</span>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.CartDetails != null && Model.CartDetails.Any())
                    {
                        <div id="cartItems">
                            @foreach (var item in Model.CartDetails)
                            {
                                <div class="cart-item border-bottom py-3" data-cart-detail-id="@item.CartDetailID">
                                    <div class="row align-items-center">
                                        <div class="col-4 col-md-2 mb-2 mb-md-0">
                                            @{
                                                string imageUrl = "/images/no-image.png";
                                                string productName = "";
                                                string productInfo = "";

                                                if (item.Variant != null)
                                                {
                                                    imageUrl = item.Variant.Product?.ProductImages?.FirstOrDefault(pi => pi.IsDefault)?.ImageUrl
                                                    ?? item.Variant.Product?.ProductImages?.FirstOrDefault()?.ImageUrl
                                                    ?? "/images/no-image.png";
                                                    productName = item.Variant.Product?.ProductName ?? "Sản phẩm";
                                                    productInfo = item.Variant.VariantName;
                                                }
                                                else if (item.Bundle != null)
                                                {
                                                    // ✅ FIX: Thêm xử lý hình ảnh cho Bundle
                                                    imageUrl = !string.IsNullOrEmpty(item.Bundle.ImageUrl) ? item.Bundle.ImageUrl :
                                                    (item.Bundle.BundleItems?.FirstOrDefault()?.Variant?.Product?.ProductImages?
                                                    .OrderByDescending(x => x.IsDefault).FirstOrDefault()?.ImageUrl ?? "/images/no-image.png");
                                                    productName = item.Bundle.Name ?? "Combo";
                                                    productInfo = $"Combo - {item.Bundle.BundleItems?.Count ?? 0} sản phẩm";
                                                }
                                            }

                                            <img src="@imageUrl" alt="@productName" class="img-fluid rounded cart-img">
                                        </div>
                                        <div class="col-8 col-md-4 mb-2 mb-md-0 custom-text-dark">
                                            <h6 class="mb-1 fw-bold text-truncate">@productName</h6>
                                            <small class="text-muted text-truncate d-block">@productInfo</small>
                                            @if (item.Variant != null)
                                            {
                                                <small class="text-muted d-block">SKU: @item.Variant.SKU</small>
                                                <small class="custom-text-accent d-block mt-1">
                                                    <i class="fas fa-box"></i> Còn: @item.Variant.Stock
                                                </small>
                                            }
                                        </div>
                                        <div class="col-6 col-md-2 text-center mb-2 mb-md-0">
                                            <div class="fw-bold custom-text-primary">@item.UnitPrice.ToString("N0")₫</div>
                                            <small class="text-muted">Đơn giá</small>
                                        </div>
                                        <div class="col-6 col-md-2 mb-2 mb-md-0">
                                            <div class="input-group quantity-group" style="max-width: 120px;">
                                                <button class="btn btn-outline-secondary btn-sm custom-btn-secondary-outline" type="button" onclick="updateQuantity(@item.CartDetailID, @item.Quantity - 1)">
                                                    <i class="fas fa-minus"></i>
                                                </button>
                                                <input type="number" class="form-control form-control-sm text-center quantity-input custom-text-dark"
                                                       value="@item.Quantity" min="1" max="@(item.Variant?.Stock ?? 999)"
                                                       data-cart-detail-id="@item.CartDetailID"
                                                       onchange="updateQuantityDirect(@item.CartDetailID, this.value)">
                                                <button class="btn btn-outline-secondary btn-sm custom-btn-secondary-outline" type="button" onclick="updateQuantity(@item.CartDetailID, @item.Quantity + 1)">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="col-6 col-md-1 text-center mb-2 mb-md-0">
                                            <div class="fw-bold item-total custom-text-primary">@item.TotalPrice.ToString("N0")₫</div>
                                            <small class="text-muted">Thành tiền</small>
                                        </div>
                                        <div class="col-6 col-md-1 text-center mb-2 mb-md-0">
                                            <button class="btn btn-outline-danger btn-sm" onclick="removeItem(@item.CartDetailID)" title="Xóa sản phẩm">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mt-4 d-flex flex-column flex-sm-row justify-content-between align-items-stretch gap-2">
                            <button class="btn btn-outline-danger w-100" onclick="clearCart()">
                                <i class="fas fa-trash-alt"></i> Xóa tất cả
                            </button>
                            <a href="@Url.Action("Index", "Products")" class="btn custom-btn-primary-outline w-100">
                                <i class="fas fa-arrow-left"></i> Tiếp tục mua sắm
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-shopping-cart fa-4x text-muted mb-4"></i>
                            <h4 class="text-muted custom-text-dark">Giỏ hàng của bạn đang trống</h4>
                            <p class="text-muted mb-4">Hãy thêm những sản phẩm yêu thích vào giỏ hàng nhé!</p>
                            <a href="@Url.Action("Index", "Products")" class="btn custom-btn-primary btn-lg">
                                <i class="fas fa-shopping-bag"></i> Khám phá sản phẩm
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (Model.CartDetails != null && Model.CartDetails.Any())
        {
            <div class="col-12 col-md-4 col-lg-4 mb-3">
                <div class="card shadow-sm sticky-top summary-card custom-card">
                    <div class="card-header custom-bg-light">
                        <h6 class="mb-0 fw-bold custom-text-dark">
                            <i class="fas fa-receipt"></i> Tóm tắt đơn hàng
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2 custom-text-dark">
                            <span>Số lượng sản phẩm:</span>
                            <span class="fw-bold">@Model.CartDetails.Sum(cd => cd.Quantity) món</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 custom-text-dark">
                            <span>Tạm tính:</span>
                            <span id="subtotal" class="fw-bold">@Model.TotalAmount.ToString("N0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 custom-text-dark">
                            <span>Phí vận chuyển:</span>
                            <span class="custom-text-accent fw-bold">Miễn phí</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 custom-text-dark">
                            <span>Giảm giá:</span>
                            <span class="custom-text-accent">0₫</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3 custom-text-dark">
                            <strong class="text-lg">Tổng cộng:</strong>
                            <strong class="custom-text-primary fs-5" id="grandTotal">@Model.TotalAmount.ToString("N0")₫</strong>
                        </div>

                        <button class="btn custom-btn-primary w-100 btn-lg mb-3" onclick="proceedToCheckout()">
                            <i class="fas fa-credit-card"></i> Thanh toán ngay
                        </button>

                        <div class="text-center">
                            <small class="text-muted custom-text-dark">
                                <i class="fas fa-shield-alt custom-text-accent"></i>
                                Thanh toán an toàn & bảo mật 100%
                            </small>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mt-3 custom-card">
                    <div class="card-header custom-bg-light">
                        <h6 class="mb-0 fw-bold custom-text-dark">
                            <i class="fas fa-ticket-alt"></i> Mã giảm giá
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="input-group">
                            <input type="text" class="form-control custom-text-dark" placeholder="Nhập mã giảm giá" id="couponCode">
                            <button class="btn custom-btn-primary" onclick="applyCoupon()">
                                Áp dụng
                            </button>
                        </div>
                        <small class="text-muted mt-2 d-block custom-text-dark">
                            <i class="fas fa-info-circle"></i>
                            Nhập mã để nhận ưu đãi đặc biệt
                        </small>
                    </div>
                </div>

                <div class="card shadow-sm mt-3 custom-card">
                    <div class="card-header custom-bg-light">
                        <h6 class="mb-0 fw-bold custom-text-dark">
                            <i class="fas fa-heart"></i> Có thể bạn sẽ thích
                        </h6>
                    </div>
                    <div class="card-body">
                        <small class="text-muted custom-text-dark">
                            <i class="fas fa-sparkles"></i>
                            Khám phá thêm những sản phẩm tuyệt vời khác!
                        </small>
                        <div class="mt-2">
                            <a href="@Url.Action("Index", "Products")" class="btn custom-btn-secondary-outline btn-sm w-100">
                                Xem thêm sản phẩm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        /* Định nghĩa biến màu CSS để dễ quản lý */
        :root {
            --primary-color: #6C4E31; /* Nâu sữa */
            --primary-light-color: #DCC5A1; /* Be kem */
            --secondary-color: #A67C52; /* Nâu nhạt */
            --accent-color: #8BC34A; /* Xanh matcha nhẹ */
            --background-light-color: #F5E9DA; /* Nền sáng */
            --text-dark-color: #2A2A2A; /* Đen xám */
        }

        /* ------------------- Màu Sắc Chung ------------------- */
        .custom-text-primary {
            color: var(--primary-color) !important;
        }

        .custom-text-dark {
            color: var(--text-dark-color) !important;
        }

        .custom-text-accent {
            color: var(--accent-color) !important;
        }

        .custom-bg-primary {
            background-color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
        }

        .custom-bg-light {
            background-color: var(--background-light-color) !important;
            border-color: var(--background-light-color) !important;
        }

        .custom-card {
            background-color: white;
            border-color: var(--primary-light-color);
        }

        .custom-text-dark h6, .custom-text-dark h5 {
            color: var(--text-dark-color) !important;
        }


        /* ------------------- Nút và Link ------------------- */
        /* Nút chính (Thanh toán, Khám phá sản phẩm) */
        .custom-btn-primary {
            background-color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
            color: white !important;
        }

            .custom-btn-primary:hover {
                background-color: var(--secondary-color) !important;
                border-color: var(--secondary-color) !important;
            }

        /* Nút viền chính (Tiếp tục mua sắm) */
        .custom-btn-primary-outline {
            color: var(--primary-color);
            border-color: var(--primary-color);
        }

            .custom-btn-primary-outline:hover {
                background-color: var(--primary-light-color) !important;
                color: var(--text-dark-color) !important;
            }

        /* Nút viền phụ (Tăng/Giảm SL, Xem thêm SP) */
        .custom-btn-secondary-outline {
            color: var(--secondary-color);
            border-color: var(--secondary-color);
        }

            .custom-btn-secondary-outline:hover {
                background-color: var(--background-light-color) !important;
                color: var(--text-dark-color) !important;
            }

        .quantity-group .custom-btn-secondary-outline {
            color: var(--text-dark-color);
            border-color: #ced4da;
        }

        /* Link (Breadcrumb) */
        .custom-link {
            color: var(--secondary-color) !important;
        }

            .custom-link:hover {
                color: var(--primary-color) !important;
            }

        /* ------------------- Chi tiết Giỏ hàng ------------------- */
        .cart-item {
            transition: background-color 0.2s ease;
        }

            .cart-item:hover {
                background-color: var(--background-light-color);
            }

        .cart-img {
            width: 100%;
            max-width: 80px;
            height: auto;
            object-fit: cover;
        }

        /* ------------------- Input và Số lượng ------------------- */
        .quantity-group .btn {
            border-radius: 0;
            padding: 0.25rem 0.5rem;
        }

        .quantity-group .form-control {
            border-radius: 0;
            border-left: 1px solid #ced4da; /* Giữ border */
            border-right: 1px solid #ced4da; /* Giữ border */
            text-align: center;
            width: 50px;
        }

        .quantity-group .btn:first-child {
            border-top-left-radius: 0.375rem;
            border-bottom-left-radius: 0.375rem;
        }

        .quantity-group .btn:last-child {
            border-top-right-radius: 0.375rem;
            border-bottom-right-radius: 0.375rem;
        }

        .form-control {
            color: var(--text-dark-color);
        }

        /* ------------------- Khối tóm tắt ------------------- */
        .sticky-top {
            position: sticky !important;
            top: 20px;
        }

        .card-header {
            border-bottom: 2px solid var(--primary-light-color);
        }

        /* ------------------- Responsive ------------------- */
        @@media (max-width: 767px) {
            .sticky-top {
                position: static !important;
                top: auto;
            }

            .quantity-group .form-control {
                width: 40px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        // *** Giữ nguyên phần logic JavaScript, vì chỉ thay đổi giao diện/màu sắc ***

        // Hàm cập nhật số lượng (dùng cho nút +/-)
        function updateQuantity(cartDetailId, newQuantity) {
            if (newQuantity < 1) {
                if (confirm('Bạn có muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                    removeItem(cartDetailId);
                }
                return;
            }
            updateQuantityDirect(cartDetailId, newQuantity);
        }

        // Hàm cập nhật số lượng trực tiếp (dùng cho input)
        function updateQuantityDirect(cartDetailId, quantity) {
            const qty = parseInt(quantity);
            if (qty < 1) return;
            const inputElement = document.querySelector(`input[data-cart-detail-id="${cartDetailId}"]`);
            const originalValue = inputElement ? inputElement.value : qty;
            if (inputElement) inputElement.disabled = true;

            fetch('/Cart/UpdateQuantity', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cartDetailId: cartDetailId, quantity: qty })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Tải lại trang để đồng bộ Total (Nên chuyển sang AJAX update nội dung để tối ưu hơn)
                    location.reload();
                } else {
                    if (inputElement) inputElement.value = originalValue;
                    toastr.error(data.message || 'Không thể cập nhật số lượng');
                }
            })
            .catch(error => {
                if (inputElement) inputElement.value = originalValue;
                toastr.error('Có lỗi xảy ra');
            })
            .finally(() => { if (inputElement) inputElement.disabled = false; });
        }

        // Hàm xóa một sản phẩm
        function removeItem(cartDetailId) {
            if (confirm('Bạn có chắc muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                fetch('/Cart/RemoveItem', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cartDetailId: cartDetailId })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        toastr.success(data.message);
                        setTimeout(() => location.reload(), 500);
                    } else toastr.error(data.message);
                })
                .catch(error => toastr.error('Có lỗi xảy ra'));
            }
        }

        // Hàm xóa toàn bộ giỏ hàng
        function clearCart() {
            if (confirm('Bạn có chắc muốn xóa tất cả sản phẩm trong giỏ hàng?')) {
                fetch('/Cart/Clear', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        toastr.success('Đã xóa tất cả sản phẩm khỏi giỏ hàng');
                        setTimeout(() => location.reload(), 500);
                    } else toastr.error(data.message);
                })
                .catch(error => toastr.error('Có lỗi xảy ra'));
            }
        }

        // Hàm tiến hành thanh toán
        function proceedToCheckout() {
            fetch('/Cart/Checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (data.redirectUrl) {
                        window.location.href = data.redirectUrl;
                    } else {
                        toastr.success(data.message);
                    }
                } else {
                    if (data.redirectUrl) {
                        toastr.warning(data.message);
                        setTimeout(() => window.location.href = data.redirectUrl, 2000);
                    } else {
                        toastr.error(data.message);
                    }
                }
            })
            .catch(error => {
                toastr.error('Có lỗi xảy ra khi xử lý đơn hàng');
            });
        }

        // Hàm áp dụng mã giảm giá (Đang phát triển)
        function applyCoupon() {
            const code = document.getElementById('couponCode').value.trim();
            if (!code) {
                toastr.warning('Vui lòng nhập mã giảm giá');
                return;
            }
            toastr.info('Tính năng mã giảm giá sẽ được phát triển sau');
        }
    </script>
}