@model IEnumerable<DrinShop.Models.Brand>

@{
    ViewData["Title"] = "Danh sách thương hiệu";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Danh sách thương hiệu</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <a href="/Brands/Edit" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm thương hiệu mới
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>STT</th>
                            <th>Tên thương hiệu</th>
                            <th>Mô tả</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int stt = 1;
                        }
                        @foreach (var brand in Model)
                        {
                            <tr>
                                <td>@stt</td>
                                <td><strong>@brand.BrandName</strong></td>
                                <td>
                                    @if (string.IsNullOrEmpty(brand.Description))
                                    {
                                        <span class="text-muted">Chưa có mô tả</span>
                                    }
                                    else
                                    {
                                        <span>@(brand.Description.Length > 100 ? brand.Description.Substring(0, 100) + "..." : brand.Description)</span>
                                    }
                                </td>
                                <td>
                                    @if (brand.Status)
                                    {
                                        <span class="badge bg-success">Kích hoạt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Vô hiệu</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Brand Actions">
                                        <a href="/Brands/Details/@brand.BrandID" class="btn btn-outline-info" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                        {
                                            <a href="/Brands/Edit/@brand.BrandID" class="btn btn-outline-warning" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-delete-brand"
                                                        data-id="@brand.BrandID"
                                                        data-name="@brand.BrandName"
                                                        title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                            stt++;
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-3">
                <p class="text-muted">Tổng số: <strong>@Model.Count()</strong> Thương hiệu</p>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <div class="mb-3">
                    <i class="bi bi-tags-fill text-muted" style="font-size: 3rem;"></i>
                </div>
                <h5 class="text-muted">Chưa có thương hiệu nào</h5>
                <p class="text-muted">Hãy thêm thương hiệu đầu tiên!</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                    <a href="/Brands/Edit" class="btn btn-success shadow-sm">
                        <i class="bi bi-plus-circle"></i> Thêm thương hiệu mới
                    </a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Xử lý xóa thương hiệu với SweetAlert2
        document.querySelectorAll('.btn-delete-brand').forEach(button => {
            button.addEventListener('click', function (e) {
                e.preventDefault();
                const brandId = this.getAttribute('data-id');
                const brandName = this.getAttribute('data-name');
                const deleteUrl = `/Brands/Delete/${brandId}`;

                Swal.fire({
                    title: 'Bạn có chắc chắn?',
                    html: `Bạn muốn xóa thương hiệu <strong>${brandName}</strong>? Hành động này không thể hoàn tác.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa!',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = deleteUrl;
                    }
                });
            });
        });

        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
