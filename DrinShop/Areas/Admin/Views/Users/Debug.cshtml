@{
    ViewData["Title"] = "Debug Users";
    var allUsers = ViewBag.AllUsers as List<dynamic> ?? new List<dynamic>();
    var googleUsers = ViewBag.GoogleUsers as List<dynamic> ?? new List<dynamic>();
    var incompleteUsers = ViewBag.IncompleteUsers as List<dynamic> ?? new List<dynamic>();
    var totalCount = ViewBag.TotalCount ?? 0;
    var errorMessage = ViewBag.ErrorMessage as string;
}

<h2>Debug User Data</h2>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        <strong>Lỗi:</strong> @errorMessage
    </div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="bi bi-people-fill"></i> Tổng số Users: @totalCount
                </h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="bi bi-google"></i> Google Users: @googleUsers.Count
                </h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Incomplete Users: @incompleteUsers.Count
                </h5>
            </div>
        </div>
    </div>
</div>
<!-- ✅ Luôn hiển thị Test Actions, kể cả khi chưa có user -->
<div class="card mt-4 border-warning">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0">🧪 Test Actions</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h6>Tạo Test Google User:</h6>
                <form asp-action="CreateTestGoogleUser" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning btn-sm">
                        <i class="bi bi-google"></i> Tạo Google User Test
                    </button>
                </form>
            </div>
            <div class="col-md-6">
                <h6>Reset IsFirstLogin cho tất cả:</h6>
                <form asp-action="ResetFirstLogin" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Đặt lại IsFirstLogin=true cho tất cả user?')">
                        <i class="bi bi-arrow-clockwise"></i> Reset FirstLogin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
@if (allUsers.Any())
{
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">Chi tiết dữ liệu Users (Raw Data)</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>FullName</th>
                            <th>Email</th>
                            <th>GoogleId (Raw)</th>
                            <th>IsFirstLogin (Raw)</th>
                            <th>Status</th>
                            <th>AppUser</th>
                            <th>RegisterDate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in allUsers)
                        {
                            <tr class="@(user.IsFirstLogin ? "table-warning" : "") @(!string.IsNullOrEmpty(user.GoogleId?.ToString()) && user.GoogleId.ToString() != "NULL" ? "table-info" : "")">
                                <td>@user.UserId</td>
                                <td>@(user.FullName ?? "<em>null</em>")</td>
                                <td>@(user.Email ?? "<em>null</em>")</td>
                                <td>
                                    <code>@(user.GoogleId ?? "NULL")</code>
                                    @if (!string.IsNullOrEmpty(user.GoogleId?.ToString()) && user.GoogleId.ToString() != "NULL")
                                    {
                                        <span class="badge bg-danger ms-1">GOOGLE</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary ms-1">LOCAL</span>
                                    }
                                </td>
                                <td>
                                    <code>@user.IsFirstLogin</code>
                                    @if (user.IsFirstLogin)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">INCOMPLETE</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success ms-1">COMPLETE</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-@(user.Status ? "success" : "secondary")">
                                        @(user.Status ? "ACTIVE" : "INACTIVE")
                                    </span>
                                </td>
                                <td>
                                    @if (user.HasApplicationUser)
                                    {
                                        <span class="badge bg-success">✓ @user.ApplicationUserEmail</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">✗ MISSING</span>
                                    }
                                </td>
                                <td>
                                    @if (user.RegisterDate != null)
                                    {
                                        @user.RegisterDate.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                    }
                                    else
                                    {
                                        <em>null</em>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    

}
else
{
    <div class="alert alert-warning text-center">
        <i class="bi bi-info-circle-fill fs-1 text-warning"></i>
        <h4 class="mt-3">Không có dữ liệu user</h4>
        <p class="mb-0">Database chưa có user nào.</p>
    </div>
}

<!-- Navigation -->
<div class="text-center mt-4">
    <a asp-action="Index" class="btn btn-primary">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách Users
    </a>
    <button onclick="location.reload()" class="btn btn-secondary">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
</div>
