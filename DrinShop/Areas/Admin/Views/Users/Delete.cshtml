@model DrinShop.Models.User

@{
    ViewData["Title"] = "Xóa khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">
        <i class="bi bi-trash"></i> @ViewData["Title"]
    </h3>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left-circle-fill"></i> Quay lại danh sách
    </a>
</div>

<div class="alert alert-danger p-4 mb-4" role="alert">
    <h4 class="alert-heading">
        <i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo: Bạn có chắc chắn muốn xóa khách hàng này không?
    </h4>
    <p>Hành động xóa khách hàng **@Model.FullName** là **không thể hoàn tác**. Hãy đảm bảo bạn đã xem xét tất cả các giao dịch liên quan (nếu có) trước khi tiến hành xóa vĩnh viễn.</p>
    <hr>
    <p class="mb-0">Nếu bạn chỉ muốn vô hiệu hóa tài khoản, hãy sử dụng chức năng **Sửa** và chuyển trạng thái sang "Ngừng hoạt động".</p>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0">Thông tin khách hàng cần xóa</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Họ tên:</dt>
            <dd class="col-sm-9"><strong>@Model.FullName</strong></dd>

            <dt class="col-sm-3">Email:</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Số điện thoại:</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Địa chỉ:</dt>
            <dd class="col-sm-9">@(Model.Address ?? "N/A")</dd>

            <dt class="col-sm-3">Trạng thái:</dt>
            <dd class="col-sm-9">
                @if (Model.Status)
                {
                    <span class="badge bg-success">Hoạt động</span>
                }
                else
                {
                    <span class="badge bg-danger">Ngừng hoạt động</span>
                }
            </dd>

            <dt class="col-sm-3">Ngày đăng ký:</dt>
            <dd class="col-sm-9">@Model.RegisterDate?.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-4">
    <input type="hidden" asp-for="UserId" />

    <button type="submit" class="btn btn-danger me-2">
        <i class="bi bi-trash-fill"></i> Xác nhận Xóa Vĩnh Viễn
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-x-circle-fill"></i> Hủy
    </a>
</form>