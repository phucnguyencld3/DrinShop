    <!-- ✅ THÊM: SweetAlert2 để thay thế toastr -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ✅ Auto show TempData messages with SweetAlert2
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: '@Html.Raw(TempData["SuccessMessage"].ToString().Replace("'", "\\'"))',
                            timer: 3000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
            </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi!',
                            text: '@Html.Raw(TempData["ErrorMessage"].ToString().Replace("'", "\\'"))',
                            timer: 5000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
            </text>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'info',
                            title: 'Thông báo!',
                            text: '@Html.Raw(TempData["InfoMessage"].ToString().Replace("'", "\\'"))',
                            timer: 4000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
            </text>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <text>
                        Swal.fire({
                            icon: 'warning',
                            title: 'Cảnh báo!',
                            text: '@Html.Raw(TempData["WarningMessage"].ToString().Replace("'", "\\'"))',
                            timer: 4000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
            </text>
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>


