        @if (TempData["ErrorMessage"] != null)
        {
            <text>toastr.error('@Html.Raw(TempData["ErrorMessage"].ToString())');</text>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <text>toastr.info('@Html.Raw(TempData["InfoMessage"].ToString())');</text>
