@model DrinShop.Models.Bundle

@{
	ViewData["Title"] = "Chi tiết combo";
	var totalOriginalPrice = Model.BundleItems?.Sum(bi => bi.Variant.UnitPrice * bi.Quantity) ?? 0;
	var bundlePrice = Model.FinalPrice;
	var discount = totalOriginalPrice > 0 && bundlePrice > 0 ? ((totalOriginalPrice - bundlePrice) / totalOriginalPrice * 100) : 0;
	var savingAmount = totalOriginalPrice - bundlePrice;

	var noImageSvg = "data:image/svg+xml,%3csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3e%3crect width='60' height='60' fill='%23f8f9fa' stroke='%23dee2e6'/%3e%3ccircle cx='30' cy='22' r='6' fill='%23adb5bd'/%3e%3cpath d='M18 45 L22 40 L26 44 L34 36 L42 44 Z' fill='%23adb5bd'/%3e%3ctext x='30' y='55' font-size='7' fill='%236c757d' text-anchor='middle'%3eNo Image%3c/text%3e%3c/svg%3e";

}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h1 class="h3 mb-0">Chi tiết combo</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
	<div class="alert alert-success alert-dismissible fade show">
		<i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
		<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
	</div>
}

@if (TempData["ErrorMessage"] != null)
{
	<div class="alert alert-danger alert-dismissible fade show">
		<i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
		<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
	</div>
}

<div class="row">
	<div class="col-md-5">
		<div class="card shadow-sm mb-3">
			<div class="card-body">
				@if (!string.IsNullOrEmpty(Model.ImageUrl))
				{
					<div class="text-center mb-3">
						<img src="@Model.ImageUrl" alt="@Model.Name"
											  class="img-fluid rounded border" style="max-height: 400px; object-fit: contain; width: 100%;" />
					</div>
				}
				else
				{
					<div class="text-center py-5">
						<div class="bg-light d-flex align-items-center justify-content-center rounded"
											  style="height: 300px;">
							<div class="text-muted">
								<i class="bi bi-image" style="font-size: 5rem;"></i>
								<p class="mt-3">Chưa có hình ảnh</p>
								@if (User.IsInRole("Admin") || User.IsInRole("Staff"))
								{
									<a asp-action="Edit" asp-route-id="@Model.BundleId" class="btn btn-sm btn-primary">
										Thêm hình ảnh
									</a>
								}
							</div>
						</div>
					</div>
				}

				<div class="mb-3 d-grid gap-2">
					@if (User.IsInRole("Admin") || User.IsInRole("Staff"))
					{
						<a asp-action="Edit" asp-route-id="@Model.BundleId" class="btn btn-warning d-flex align-items-center justify-content-center">
							<i class="bi bi-pencil-square me-2"></i> **Chỉnh sửa combo**
							<small class="ms-2">(Sửa thông tin, thêm/bớt sản phẩm)</small>
						</a>
					}

					<a asp-action="Index" class="btn btn-outline-info d-flex align-items-center justify-content-center">
						<i class="bi bi-list me-2"></i> **Xem tất cả combo**
						<small class="ms-2">(Quay lại danh sách combo)</small>
					</a>

				</div>
				<div class="card border-success mt-3">
					<div class="card-body">
						<div class="text-center">
							@if (totalOriginalPrice > 0)
							{
								<p class="text-muted mb-2">
									<small>Giá gốc:</small>
									<del class="fs-5">@totalOriginalPrice.ToString("N0")₫</del>
								</p>
							}
							<p class="text-success mb-2 fw-bold" style="font-size: 2rem;">
								@bundlePrice.ToString("N0")₫
							</p>
							@if (discount > 0)
							{
								<span class="badge bg-danger fs-6 mb-2">
									Giảm @discount.ToString("0")%
								</span>
								<p class="text-success mb-0">
									<i class="bi bi-piggy-bank"></i>
									Tiết kiệm: <strong>@savingAmount.ToString("N0")₫</strong>
								</p>
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="col-md-7">
		<div class="card shadow-sm">
			<div class="card-header bg-primary text-white">
				<h5 class="mb-0">Thông tin combo</h5>
			</div>
			<div class="card-body">
				<h3 class="mb-3">@Model.Name</h3>

				<dl class="row mb-0">
					<dt class="col-sm-4">Mã combo</dt>
					<dd class="col-sm-8">
						<code>@Model.Code</code>
					</dd>

					<dt class="col-sm-4">Số sản phẩm</dt>
					<dd class="col-sm-8">
						@if (Model.BundleItems != null && Model.BundleItems.Any())
						{
							<span class="badge bg-primary fs-6">
								<i class="bi bi-box-seam"></i> @Model.BundleItems.Count sản phẩm
							</span>
							<br />
							<small class="text-muted">
								Tổng số lượng: @Model.BundleItems.Sum(bi => bi.Quantity) items
							</small>
						}
						else
						{
							<span class="badge bg-warning text-dark fs-6">
								<i class="bi bi-exclamation-triangle"></i> Chưa có sản phẩm
							</span>
						}
					</dd>

					<dt class="col-sm-4">Giá combo</dt>
					<dd class="col-sm-8">
						<strong class="text-success fs-4">@bundlePrice.ToString("N0")₫</strong>
						@if (discount > 0)
						{
							<span class="badge bg-danger ms-2">-@discount.ToString("0")%</span>
						}
					</dd>

					<dt class="col-sm-4">Trạng thái</dt>
					<dd class="col-sm-8">
						@if (Model.Status)
						{
							<span class="badge bg-success fs-6">
								<i class="bi bi-check-circle"></i> Đang hoạt động
							</span>
						}
						else
						{
							<span class="badge bg-secondary fs-6">
								<i class="bi bi-x-circle"></i> Ngừng hoạt động
							</span>
						}
					</dd>

					<dt class="col-sm-4">Người tạo</dt>
					<dd class="col-sm-8">
						@if (!string.IsNullOrEmpty(Model.CreatedBy))
						{
							<span class="badge bg-info">@Model.CreatedBy</span>
						}
						else
						{
							<span class="text-muted">-</span>
						}
					</dd>

					<dt class="col-sm-4">Ngày tạo</dt>
					<dd class="col-sm-8">
						<small class="text-muted">
							@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
						</small>
					</dd>

					<hr class="my-3" />
				</dl>

				@if (!string.IsNullOrEmpty(Model.Description))
				{
					<h6><strong>Mô tả combo:</strong></h6>
					<div class="card bg-light">
						<div class="card-body">
							<p class="mb-0">@Html.Raw(Model.Description.Replace(Environment.NewLine, "<br/>"))</p>
						</div>
					</div>
					<hr class="my-3" />
				}

				@if (Model.BundleItems != null && Model.BundleItems.Any())
				{
					<div class="mb-4">
						<div class="d-flex justify-content-between align-items-center mb-3">
							<h6 class="fw-bold mb-0">
								<i class="bi bi-box2-heart"></i> Sản phẩm trong combo
								<span class="badge bg-primary">@Model.BundleItems.Count</span>
							</h6>
							@if (User.IsInRole("Admin") || User.IsInRole("Staff"))
							{
								<a asp-action="Edit" asp-route-id="@Model.BundleId" class="btn btn-sm btn-info">
									<i class="bi bi-pencil"></i> Chỉnh sửa
								</a>
							}
						</div>

						<div class="table-responsive">
							<table class="table table-sm table-striped align-middle">
								<thead class="table-dark">
									<tr>
										<th style="width: 60px;">Ảnh</th>
										<th>Sản phẩm</th>
										<th>Danh mục</th>
										<th class="text-center">SL</th>
										<th class="text-end">Đơn giá</th>
										<th class="text-end">Thành tiền</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Model.BundleItems.OrderBy(bi => bi.BundleItemId))
									{
										var productImage = item.Variant?.Product?.ProductImages?
										.OrderByDescending(x => x.IsDefault)
										.ThenBy(x => x.SortOrder)
										.FirstOrDefault()?.ImageUrl ?? noImageSvg;
										var subtotal = item.Variant.UnitPrice * item.Quantity;

										<tr>
											<td class="text-center">
												<img src="@productImage"
																					alt="@item.Variant.Product.ProductName"
																					class="img-thumbnail"
																					style="width: 45px; height: 45px; object-fit: cover;" />
											</td>
											<td>
												<strong>@item.Variant.Product.ProductName</strong>
												<br />
												<small class="text-muted">
													@item.Variant.VariantName
												</small>
												<br />
												<code style="font-size: 0.75rem;">@item.Variant.SKU</code>
											</td>
											<td>
												<span class="badge bg-info">
													@(item.Variant.Product.Category?.CategoryName ?? "N/A")
												</span>
											</td>
											<td class="text-center">
												<span class="badge bg-primary">×@item.Quantity</span>
											</td>
											<td class="text-end">
												<span class="text-muted">@item.Variant.UnitPrice.ToString("N0")₫</span>
											</td>
											<td class="text-end">
												<strong>@subtotal.ToString("N0")₫</strong>
											</td>
										</tr>
									}
								</tbody>
								<tfoot class="table-light">
									<tr>
										<td colspan="5" class="text-end fw-bold">Tổng giá gốc:</td>
										<td class="text-end">
											<strong class="text-muted">@totalOriginalPrice.ToString("N0")₫</strong>
										</td>
									</tr>
									@if (discount > 0)
									{
										<tr class="table-danger">
											<td colspan="5" class="text-end fw-bold">Giảm giá (@discount.ToString("0")%):</td>
											<td class="text-end">
												<strong class="text-danger">-@savingAmount.ToString("N0")₫</strong>
											</td>
										</tr>
									}
									<tr class="table-success">
										<td colspan="5" class="text-end fw-bold fs-5">Giá combo:</td>
										<td class="text-end">
											<strong class="text-success fs-5">@bundlePrice.ToString("N0")₫</strong>
										</td>
									</tr>
								</tfoot>
							</table>
						</div>
					</div>
				}
				else
				{
					<div class="alert alert-warning">
						<div class="d-flex align-items-center">
							<i class="bi bi-exclamation-triangle me-2"></i>
							<div>
								<strong>Chưa có sản phẩm trong combo</strong>
								<br />
								<small>Hãy thêm sản phẩm để hoàn thiện combo</small>
							</div>
						</div>
						@if (User.IsInRole("Admin") || User.IsInRole("Staff"))
						{
							<hr />
							<a asp-action="Edit" asp-route-id="@Model.BundleId" class="btn btn-sm btn-warning">
								<i class="bi bi-plus-circle"></i> Thêm sản phẩm
							</a>
						}
					</div>
				}

			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		$(document).ready(function() {
			// Auto hide alerts
			setTimeout(function() {
				$('.alert-dismissible').fadeOut('slow');
			}, 3000);

			// Tooltip
			$('[title]').tooltip();

			// Hover effect cho cards
			$('.card').hover(
				function() {
					$(this).addClass('shadow-lg');
				},
				function() {
					$(this).removeClass('shadow-lg');
				}
			);
		});
	</script>

	<style>
					.badge {
							font-size: 0.75em;

		}

					.card:hover {
							box-shadow: 0 4px 8px rgba(0,0,0,0.1);
							transition: box-shadow 0.3s ease;

		}

					.alert {
							border: none;
							border-radius: 0.5rem;

		}

					.table th {
							font-size: 0.875rem;
							font-weight: 600;

		}

					.table td {
							font-size: 0.875rem;
							vertical-align: middle;

		}

					.table tfoot tr td {
							border-top: 2px solid #dee2e6;

		}

					.img-thumbnail {
							border-radius: 0.5rem;

		}

					code {
							background-color: #f8f9fa;
							padding: 2px 6px;
							border-radius: 3px;
							color: #d63384;

		}




	</style>
}