@model DrinShop.Models.Variant
@{
    ViewData["Title"] = "Thêm biến thể thủ công";
    var product = ViewBag.Product as DrinShop.Models.Product;
    var productOptions = ViewBag.ProductOptions as List<DrinShop.Models.ProductOption>;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-plus-circle"></i>
                        Thêm biến thể cho: <strong>@product.ProductName</strong>
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Index" asp-route-id="@product.ProductID" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </div>

                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="CreateDate" />
                    <input type="hidden" asp-for="CreatedBy" />
                    <input type="hidden" asp-for="Status" />

                    <div class="card-body">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="VariantName" class="form-label">Tên biến thể <span class="text-danger">*</span></label>
                                    <input asp-for="VariantName" class="form-control" placeholder="VD: Trà sữa Size L + Trân châu">
                                    <span asp-validation-for="VariantName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="SKU" class="form-label">SKU</label>
                                    <input asp-for="SKU" class="form-control" placeholder="Để trống để tự động tạo">
                                    <span asp-validation-for="SKU" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="UnitPrice" class="form-label">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <input asp-for="UnitPrice" type="number" class="form-control" step="0.01" min="0">
                                        <span class="input-group-text">₫</span>
                                    </div>
                                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Stock" class="form-label">Tồn kho</label>
                                    <input asp-for="Stock" type="number" class="form-control" min="0" placeholder="0">
                                    <span asp-validation-for="Stock" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả chi tiết về biến thể này (tùy chọn)"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        @if (productOptions != null && productOptions.Any())
                        {
                            <div class="form-group">
                                <label class="form-label">Chọn thuộc tính <span class="text-danger">*</span></label>
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i>
                                    Bạn cần chọn đúng một giá trị cho mỗi thuộc tính của sản phẩm.
                                </div>

                                @foreach (var option in productOptions)
                                {
                                    <div class="card mb-3">
                                        <div class="card-header py-2">
                                            <strong>@option.Name</strong>
                                            @if (option.PriceModifer != 0)
                                            {
                                                <span class="badge badge-info">@(option.PriceModifer > 0 ? "+" : "")@option.PriceModifer.ToString("N0")₫</span>
                                            }
                                        </div>
                                        <div class="card-body py-2">
                                            @foreach (var value in option.Values)
                                            {
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input option-radio"
                                                           type="radio"
                                                           name="option_@option.ProductOptionId"
                                                           id="option_@(option.ProductOptionId)_@value.ProductOptionValueId"
                                                           value="@value.ProductOptionValueId"
                                                           data-option-id="@option.ProductOptionId">
                                                    <label class="form-check-label" for="option_@(option.ProductOptionId)_@value.ProductOptionValueId">
                                                        @value.Value
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                                Sản phẩm này chưa có thuộc tính nào.
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" class="alert-link">
                                    Vui lòng thêm thuộc tính trước khi tạo biến thể.
                                </a>
                            </div>
                        }
                    </div>

                    <div class="card-footer">
                        <div class="row">
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-success" id="submitBtn">
                                    <i class="fas fa-save"></i> Tạo biến thể
                                </button>
                                <a asp-action="Index" asp-route-id="@product.ProductID" class="btn btn-secondary ml-2">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                            </div>
                            <div class="col-md-6 text-right">
                                <small class="text-muted">
                                    <i class="fas fa-info-circle"></i>
                                    Biến thể sẽ được tạo với trạng thái "Đang bán"
                                </small>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Auto-generate variant name based on selected options
            $('.option-radio').change(function() {
                generateVariantName();
                calculatePrice();
            });

            function generateVariantName() {
                const selectedOptions = [];
                $('.option-radio:checked').each(function() {
                    const label = $('label[for="' + $(this).attr('id') + '"]').text().trim();
                    selectedOptions.push(label);
                });

                if (selectedOptions.length > 0) {
                    const baseName = '@product.ProductName';
                    const variantName = baseName + ' - ' + selectedOptions.join(' + ');
                    $('#VariantName').val(variantName);
                }
            }

            function calculatePrice() {
                let totalPrice = parseFloat($('#UnitPrice').val()) || 0;
                let basePrice = totalPrice;

                // Calculate price modifiers (if any)
                $('.option-radio:checked').each(function() {
                    const optionId = $(this).data('option-id');
                    // You could add price modifier logic here if needed
                });

                // Update price display or calculation if needed
            }

            // Form validation
            $('form').submit(function(e) {
                let isValid = true;
                const errors = [];

                // Check if variant name is provided
                if (!$('#VariantName').val().trim()) {
                    errors.push('Vui lòng nhập tên biến thể');
                    isValid = false;
                }

                // Check if price is valid
                const price = parseFloat($('#UnitPrice').val());
                if (!price || price <= 0) {
                    errors.push('Vui lòng nhập giá bán hợp lệ');
                    isValid = false;
                }

                // Check if all options are selected
                const totalOptions = @(productOptions?.Count ?? 0);
                const selectedOptions = $('.option-radio:checked').length;

                if (totalOptions > 0 && selectedOptions !== totalOptions) {
                    errors.push('Vui lòng chọn đúng một giá trị cho mỗi thuộc tính');
                    isValid = false;
                }

                if (!isValid) {
                    e.preventDefault();
                    toastr.error(errors.join('<br>'));
                    return false;
                }

                // Show loading
                $('#submitBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang tạo...');
            });

            // Initialize
            if ($('.option-radio:checked').length > 0) {
                generateVariantName();
            }
        });
    </script>
}

