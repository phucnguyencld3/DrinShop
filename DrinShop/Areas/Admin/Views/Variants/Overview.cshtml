@model List<DrinShop.Models.Variant>
@{
    ViewData["Title"] = "Tổng quan biến thể";
    var stats = ViewBag.Statistics;
    var searchTerm = ViewBag.SearchTerm ?? "";
    var productId = ViewBag.ProductId;
    var status = ViewBag.Status;
    var products = ViewBag.Products as List<dynamic>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-lg-3 col-6">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>@stats.TotalVariants</h3>
                    <p>Tổng biến thể</p>
                </div>
                <div class="icon">
                    <i class="fas fa-boxes"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-success">
                <div class="inner">
                    <h3>@stats.ActiveVariants</h3>
                    <p>Đang hoạt động</p>
                </div>
                <div class="icon">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-warning">
                <div class="inner">
                    <h3>@stats.InactiveVariants</h3>
                    <p>Ngừng hoạt động</p>
                </div>
                <div class="icon">
                    <i class="fas fa-times-circle"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-primary">
                <div class="inner">
                    <h3>@stats.TotalStock</h3>
                    <p>Tổng tồn kho</p>
                </div>
                <div class="icon">
                    <i class="fas fa-warehouse"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-list"></i>
                        Danh sách biến thể
                    </h3>
                </div>

                <div class="card-body">
                    <form method="get" class="mb-3">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Tìm kiếm</label>
                                    <input type="text" name="searchTerm" class="form-control"
                                           placeholder="Tên biến thể, sản phẩm, SKU..."
                                           value="@searchTerm">
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Sản phẩm</label>
                                    <select name="productId" class="form-control">
                                        <option value="">-- Tất cả sản phẩm --</option>
                                        @if (products != null)
                                        {
                                            @foreach (var product in products)
                                            {
                                                <option value="@product.ProductID"
                                                        selected="@(productId == product.ProductID)">
                                                    @product.ProductName
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Trạng thái</label>
                                    <select name="status" class="form-control">
                                        <option value="">-- Tất cả --</option>
                                        <option value="true" selected="@(status == true)">Hoạt động</option>
                                        <option value="false" selected="@(status == false)">Ngừng hoạt động</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>&nbsp;</label>
                                    <button type="submit" class="btn btn-primary btn-block">
                                        <i class="fas fa-search"></i> Lọc
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th width="50">#</th>
                                        <th>Sản phẩm</th>
                                        <th>Tên biến thể</th>
                                        <th>Thuộc tính</th>
                                        <th>SKU</th>
                                        <th>Giá</th>
                                        <th>Tồn kho</th>
                                        <th>Trạng thái</th>
                                        <th>Ngày tạo</th>
                                        <th width="150">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var variant in Model)
                                    {
                                        <tr>
                                            <td>@variant.VariantID</td>
                                            <td>
                                                <strong>@variant.Product.ProductName</strong>
                                                <br>
                                                <small class="text-muted">
                                                    @(variant.Product.Category?.CategoryName ?? "N/A")
                                                </small>
                                            </td>
                                            <td>@variant.VariantName</td>
                                            <td>
                                                @if (variant.VariantOptionValues.Any())
                                                {
                                                    @foreach (var vov in variant.VariantOptionValues)
                                                    {
                                                        <span class="badge mr-1" style="background-color: black; color: white;">
                                                            @vov.ProductOptionValue.ProductOption.Name:
                                                            @vov.ProductOptionValue.Value
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span style="background-color: black; color: white; padding: 0.25em 0.5em; border-radius: 0.25rem;">
                                                        Không có
                                                    </span>
                                                }
                                            </td>

                                            <td>
                                                <code>@variant.SKU</code>
                                            </td>
                                            <td>
                                                <strong class="text-success">
                                                    @variant.UnitPrice.ToString("N0")₫
                                                </strong>
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill bg-success" style="font-size: 0.9rem; padding: 0.5em 0.6em;">
                                                    @variant.Stock
                                                </span>
                                            </td>
                                            <td>
                                                @if (variant.Status)
                                                {
                                                    <span class="badge badge-black">
                                                        <i class="fas fa-check"></i> Hoạt động
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-black">
                                                        <i class="fas fa-times"></i> Ngừng
                                                    </span>
                                                }
                                            </td>

                                            <td>
                                                <small>@(variant.CreateDate?.ToString("dd/MM/yyyy") ?? "N/A")</small>
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a asp-action="Details" asp-route-id="@variant.VariantID"
                                                       class="btn btn-info" title="Chi tiết">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@variant.VariantID"
                                                       class="btn btn-warning" title="Sửa">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-danger delete-variant"
                                                            data-id="@variant.VariantID"
                                                            data-name="@variant.VariantName"
                                                            title="Xóa">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle"></i>
                            Không tìm thấy biến thể nào phù hợp với tiêu chí lọc.
                        </div>
                    }
                </div>

                <div class="card-footer">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i>
                                Hiển thị tối đa 100 biến thể gần nhất
                            </small>
                        </div>
                        <div class="col-md-6 text-right">
                            @if (!string.IsNullOrEmpty(searchTerm) || productId != null || status != null)
                            {
                                <a asp-action="Overview" class="btn btn-secondary btn-sm">
                                    <i class="fas fa-times"></i> Xóa bộ lọc
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Delete variant
            $('.delete-variant').click(function() {
                const variantId = $(this).data('id');
                const variantName = $(this).data('name');

                Swal.fire({
                    title: 'Xác nhận xóa',
                    html: `Bạn có chắc muốn xóa biến thể <strong>"${variantName}"</strong>?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('@Url.Action("Delete", "Variants")', { id: variantId })
                            .done(function(response) {
                                if (response.success) {
                                    Swal.fire('Đã xóa!', response.message, 'success')
                                        .then(() => location.reload());
                                } else {
                                    if (response.canForceDelete) {
                                        // Hiển thị tùy chọn xóa cưỡng bức
                                        Swal.fire({
                                            title: 'Không thể xóa',
                                            html: `${response.message}<br><br>Bạn có muốn <strong>xóa cưỡng bức</strong> không?`,
                                            icon: 'error',
                                            showCancelButton: true,
                                            confirmButtonColor: '#d33',
                                            cancelButtonColor: '#3085d6',
                                            confirmButtonText: 'Xóa cưỡng bức',
                                            cancelButtonText: 'Hủy'
                                        }).then((result) => {
                                            if (result.isConfirmed) {
                                                forceDeleteVariant(variantId);
                                            }
                                        });
                                    } else {
                                        Swal.fire('Lỗi!', response.message, 'error');
                                    }
                                }
                            })
                            .fail(function() {
                                Swal.fire('Lỗi!', 'Có lỗi xảy ra khi xóa biến thể', 'error');
                            });
                    }
                });
            });

            function forceDeleteVariant(variantId) {
                $.post('@Url.Action("ForceDelete", "Variants")', {
                    id: variantId,
                    confirmForce: true
                })
                .done(function(response) {
                    if (response.success) {
                        Swal.fire('Đã xóa!', response.message, 'success')
                            .then(() => location.reload());
                    } else {
                        Swal.fire('Lỗi!', response.message, 'error');
                    }
                })
                .fail(function() {
                    Swal.fire('Lỗi!', 'Có lỗi xảy ra khi xóa cưỡng bức', 'error');
                });
            }
        });
    </script>

    <style>
        .small-box {
            border-radius: 0.25rem;
            box-shadow: 0 0 1px rgba(0,0,0,.125), 0 1px 3px rgba(0,0,0,.2);
            display: block;
            margin-bottom: 20px;
            position: relative;
        }

            .small-box > .inner {
                padding: 10px;
            }

            .small-box h3 {
                font-size: 2.2rem;
                font-weight: 700;
                margin: 0 0 10px;
                padding: 0;
                white-space: nowrap;
            }

            .small-box p {
                font-size: 1rem;
            }

            .small-box > .icon {
                color: rgba(0,0,0,.15);
                position: absolute;
                right: 15px;
                top: 15px;
                transition: all .3s linear;
            }

                .small-box > .icon > i {
                    font-size: 70px;
                }

        .table td {
            vertical-align: middle;
        }

       
        .table thead th {
            background-color: #000000 !important; 
            color: #FFFFFF !important; 
            border-color: #454d55; 
        }

        .badge {
            font-size: 0.75rem;
        }

        code {
            color: #e83e8c;
            background-color: #f8f9fa;
            padding: 2px 6px;
            border-radius: 3px;
        }

        .badge-black {
            background-color: black !important;
            color: white !important;
        }

    </style>
}